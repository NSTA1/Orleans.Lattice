@page "/parts/{Serial}"
@implements IDisposable
@inject FederationRouter Router
@inject DashboardBroadcaster Broadcaster
@inject OperatorActions Actions
@inject NavigationManager Nav

<PageTitle>@Serial · Part detail</PageTitle>

<p><a href="/">← Back to inventory</a></p>

<hgroup>
    <h1><code>@Serial</code></h1>
    <p>Evidence trail + operator actions for this part.</p>
</hgroup>

@if (_loadError is not null)
{
    <article><p role="alert">@_loadError</p></article>
}
else if (_facts is null)
{
    <p aria-busy="true">Loading part…</p>
}
else
{
    <div class="part-detail-grid">
        <article>
            <header><strong>State</strong></header>
            <dl>
                <dt>Baseline</dt><dd><StateBadge State="@_baselineState" /></dd>
                <dt>Lattice</dt><dd><StateBadge State="@_latticeState" /></dd>
                <dt>Facts</dt><dd>@_facts.Count</dd>
            </dl>
        </article>

        <article>
            <header><strong>Fact trail</strong></header>
            @if (_facts.Count == 0)
            {
                <p><em>No facts yet.</em></p>
            }
            else
            {
                <ol>
                    @foreach (var fact in _facts.OrderBy(f => f.Hlc.WallClockTicks).ThenBy(f => f.Hlc.Counter))
                    {
                        <li>
                            <small><code>@fact.Hlc</code> · @fact.Site · @fact.Operator.Value</small><br />
                            <strong>@fact.GetType().Name</strong>: @fact.Description
                        </li>
                    }
                </ol>
            }
        </article>
    </div>

    <h2>Record action</h2>

    <details open>
        <summary>Complete process step</summary>
        <form @onsubmit="CompleteStepAsync" @onsubmit:preventDefault>
            <label>Stage
                <select @bind="_stepStage">
                    @foreach (var s in _stages) { <option value="@s">@s</option> }
                </select>
            </label>
            <label>Heat lot (optional)<input type="text" @bind="_heatLot" /></label>
            <button type="submit" disabled="@_busy">Emit ProcessStepCompleted</button>
        </form>
    </details>

    <details>
        <summary>Record inspection</summary>
        <form @onsubmit="RecordInspectionAsync" @onsubmit:preventDefault>
            <label>Inspection
                <select @bind="_inspection">
                    @foreach (var i in _inspections) { <option value="@i">@i</option> }
                </select>
            </label>
            <label>Outcome
                <select @bind="_inspectionOutcome">
                    @foreach (var o in _outcomes) { <option value="@o">@o</option> }
                </select>
            </label>
            <label>Site
                <select @bind="_inspectionSite">
                    @foreach (var s in _sites) { <option value="@s">@s</option> }
                </select>
            </label>
            <button type="submit" disabled="@_busy">Emit InspectionRecorded</button>
        </form>
    </details>

    <details>
        <summary>Raise non-conformance</summary>
        <form @onsubmit="RaiseNcAsync" @onsubmit:preventDefault>
            <label>NC number<input type="text" @bind="_ncNumber" placeholder="NC-2025-0001" /></label>
            <label>Defect code<input type="text" @bind="_defectCode" placeholder="CRACK" /></label>
            <label>Severity
                <select @bind="_ncSeverity">
                    @foreach (var s in _severities) { <option value="@s">@s</option> }
                </select>
            </label>
            <label>Site
                <select @bind="_ncSite">
                    @foreach (var s in _sites) { <option value="@s">@s</option> }
                </select>
            </label>
            <button type="submit" disabled="@_busy">Emit NonConformanceRaised</button>
        </form>
    </details>

    <details>
        <summary>MRB disposition</summary>
        <form @onsubmit="DispositionAsync" @onsubmit:preventDefault>
            <label>NC number<input type="text" @bind="_mrbNcNumber" /></label>
            <label>Disposition
                <select @bind="_mrbKind">
                    @foreach (var d in _dispositions) { <option value="@d">@d</option> }
                </select>
            </label>
            <button type="submit" disabled="@_busy">Emit MrbDisposition</button>
        </form>
    </details>

    <details>
        <summary>Complete rework</summary>
        <form @onsubmit="CompleteReworkAsync" @onsubmit:preventDefault>
            <label>Rework operation<input type="text" @bind="_reworkOp" placeholder="Weld repair" /></label>
            <label><input type="checkbox" @bind="_retestPassed" role="switch" /> Retest passed</label>
            <button type="submit" disabled="@_busy">Emit ReworkCompleted</button>
        </form>
    </details>

    <details>
        <summary>Sign-off FAI</summary>
        <form @onsubmit="SignOffFaiAsync" @onsubmit:preventDefault>
            <label>FAI report id<input type="text" @bind="_faiReportId" /></label>
            <label>Inspector id<input type="text" @bind="_inspectorId" /></label>
            <label><input type="checkbox" @bind="_certIssued" role="switch" /> Certificate issued</label>
            <button type="submit" disabled="@_busy">Emit FinalAcceptance</button>
        </form>
    </details>

    @if (_actionError is not null)
    {
        <p role="alert" style="color:var(--pico-color-red-500)">@_actionError</p>
    }
}

@code {
    private const string LatticeBackendName = "lattice";
    private const string BaselineBackendName = "baseline";

    [Parameter] public string Serial { get; set; } = "";

    private IReadOnlyList<Fact>? _facts;
    private ComplianceState _baselineState;
    private ComplianceState _latticeState;
    private string? _loadError;
    private string? _actionError;
    private bool _busy;
    private CancellationTokenSource? _cts;

    // Form state
    private static readonly ProcessStage[] _stages =
        [ProcessStage.Forge, ProcessStage.HeatTreat, ProcessStage.Machining,
         ProcessStage.NDT, ProcessStage.MRB, ProcessStage.FAI];
    private static readonly Inspection[] _inspections = Enum.GetValues<Inspection>();
    private static readonly InspectionOutcome[] _outcomes = Enum.GetValues<InspectionOutcome>();
    private static readonly ProcessSite[] _sites = Enum.GetValues<ProcessSite>();
    private static readonly NcSeverity[] _severities = Enum.GetValues<NcSeverity>();
    private static readonly MrbDispositionKind[] _dispositions = Enum.GetValues<MrbDispositionKind>();

    private ProcessStage _stepStage = ProcessStage.Forge;
    private string? _heatLot;
    private Inspection _inspection = _inspections[0];
    private InspectionOutcome _inspectionOutcome = InspectionOutcome.Pass;
    private ProcessSite _inspectionSite = ProcessSite.ToulouseNdtLab;
    private string _ncNumber = "";
    private string _defectCode = "";
    private NcSeverity _ncSeverity = NcSeverity.Major;
    private ProcessSite _ncSite = ProcessSite.CincinnatiMrb;
    private string _mrbNcNumber = "";
    private MrbDispositionKind _mrbKind = MrbDispositionKind.UseAsIs;
    private string _reworkOp = "";
    private bool _retestPassed = true;
    private string _faiReportId = "";
    private string _inspectorId = "";
    private bool _certIssued = true;

    protected override async Task OnParametersSetAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await ReloadAsync(_cts.Token);

        // Auto-refresh when any fact routes for this serial.
        _ = ConsumeAsync(_cts.Token);
    }

    private async Task ReloadAsync(CancellationToken ct)
    {
        try
        {
            var serial = new PartSerialNumber(Serial);
            var lattice = Router.GetBackend(LatticeBackendName);
            var baseline = Router.GetBackend(BaselineBackendName);
            _facts = await lattice.GetFactsAsync(serial, ct);
            _baselineState = await baseline.GetStateAsync(serial, ct);
            _latticeState = await lattice.GetStateAsync(serial, ct);
            _loadError = null;
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            _loadError = $"Failed to load part: {ex.Message}";
        }
    }

    private async Task ConsumeAsync(CancellationToken ct)
    {
        try
        {
            await foreach (var update in Broadcaster.SubscribePartUpdates(ct))
            {
                if (update.Serial.Value == Serial)
                {
                    await ReloadAsync(ct);
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException) { }
    }

    private Task CompleteStepAsync() => RunAsync(ct =>
        Actions.CompleteProcessStepAsync(
            new PartSerialNumber(Serial), _stepStage, OperatorId.Demo,
            heatLot: string.IsNullOrWhiteSpace(_heatLot) ? null : _heatLot,
            cancellationToken: ct));

    private Task RecordInspectionAsync() => RunAsync(ct =>
        Actions.RecordInspectionAsync(
            new PartSerialNumber(Serial), _inspection, _inspectionOutcome,
            _inspectionSite, OperatorId.Demo, cancellationToken: ct));

    private Task RaiseNcAsync() => RunAsync(ct =>
        Actions.RaiseNonConformanceAsync(
            new PartSerialNumber(Serial), _ncNumber, _defectCode, _ncSeverity,
            _ncSite, OperatorId.Demo, cancellationToken: ct));

    private Task DispositionAsync() => RunAsync(ct =>
        Actions.DispositionMrbAsync(
            new PartSerialNumber(Serial), _mrbNcNumber, _mrbKind,
            OperatorId.Demo, cancellationToken: ct));

    private Task CompleteReworkAsync() => RunAsync(ct =>
        Actions.CompleteReworkAsync(
            new PartSerialNumber(Serial), _reworkOp, _retestPassed,
            OperatorId.Demo, cancellationToken: ct));

    private Task SignOffFaiAsync() => RunAsync(ct =>
        Actions.SignOffFaiAsync(
            new PartSerialNumber(Serial), _faiReportId, _inspectorId,
            _certIssued, OperatorId.Demo, cancellationToken: ct));

    private async Task RunAsync(Func<CancellationToken, Task> action)
    {
        if (_busy) return;
        _busy = true;
        _actionError = null;
        try
        {
            await action(_cts?.Token ?? CancellationToken.None);
            await ReloadAsync(_cts?.Token ?? CancellationToken.None);
        }
        catch (Exception ex)
        {
            _actionError = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
