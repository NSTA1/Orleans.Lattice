@inherits LayoutComponentBase

<header class="container">
    <nav>
        <ul>
            <li><strong>Multi-Site Manufacturing</strong></li>
            <li><small>Digital Thread Demo</small></li>
        </ul>
        <ul>
            <li><small>operator: <kbd>demo</kbd></small></li>
            <li>
                <button class="secondary"
                        aria-expanded="@_chaosOpen.ToString().ToLowerInvariant()"
                        aria-controls="chaos-flyout"
                        @onclick="ToggleChaos">
                    ☰ Chaos
                </button>
            </li>
        </ul>
    </nav>
</header>

<main class="container">
    @Body
</main>

<ChaosFlyout IsOpen="_chaosOpen" OnClose="CloseChaos" />

<footer class="container">
    <small>
        Orleans.Lattice sample · baseline vs lattice federation ·
        Pico.css (CDN) · Blazor Server
    </small>
</footer>

@code {
    private bool _chaosOpen;

    private void ToggleChaos() => _chaosOpen = !_chaosOpen;
    private void CloseChaos() => _chaosOpen = false;
}

<style>
    /* State badges — intentionally tiny; a full design pass comes in M12. */
    .state-badge {
        display: inline-block;
        padding: 0.15rem 0.5rem;
        border-radius: 0.25rem;
        font-size: 0.8rem;
        font-weight: 600;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .state-nominal          { background: #2d8a3e; }
    .state-underinspection  { background: #3b7ab8; }
    .state-flaggedforreview { background: #d18f2a; }
    .state-rework           { background: #d46b2a; }
    .state-scrap            { background: #b83a3a; }

    .chaos-banner {
        margin-bottom: 1rem;
    }
    .divergent-row td {
        background-color: rgba(184, 58, 58, 0.08);
    }
    .dashboard-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1.5rem;
    }
    @@media (max-width: 960px) {
        .dashboard-grid { grid-template-columns: 1fr; }
    }

    /* Chaos fly-out (M10). Slides in from the right; the scrim sits
       underneath to dim the dashboard and close on outside-click. */
    .chaos-flyout {
        position: fixed;
        top: 0;
        right: 0;
        height: 100vh;
        width: min(1100px, 100vw);
        background: var(--pico-background-color);
        border-left: 1px solid var(--pico-muted-border-color);
        box-shadow: -4px 0 16px rgba(0, 0, 0, 0.15);
        transform: translateX(100%);
        transition: transform 0.25s ease-in-out;
        overflow-y: auto;
        padding: 1rem 1.5rem;
        z-index: 1000;
    }
    .chaos-flyout.open {
        transform: translateX(0);
    }
    .chaos-flyout-scrim {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 999;
    }
    .chaos-flyout section {
        margin-top: 1.5rem;
    }
    .chaos-flyout .backend-row {
        padding: 0.75rem 1rem;
    }
    /* Per-site table: give numeric inputs enough room for 4-5 digit
       values (e.g. "8000" ms) without clipping. Pico's default narrow
       table input style was crushing them. */
    .chaos-flyout table input[type="number"] {
        min-width: 6rem;
        width: 100%;
    }
    .chaos-flyout table td,
    .chaos-flyout table th {
        white-space: nowrap;
    }
    .preset-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .preset-buttons button {
        flex: 1 1 auto;
    }
</style>
